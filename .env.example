# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-your-api-key-here

# Generation model — fast & cheap (optional, default: deepseek-chat)
GENERATION_MODEL=deepseek-chat

# Validation model — powerful & rigorous (optional, default: deepseek-chat)
VALIDATION_MODEL=deepseek-chat

# Response Validation (optional)
ENABLE_VALIDATION=true
VALIDATION_THRESHOLD=60
RETRY_WITH_PRO_MODEL=true

# Pre-downloaded model directory (optional)
# LOCAL_MODEL_DIR=./models

# Chinese embedding model (optional, uncomment after downloading)
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
